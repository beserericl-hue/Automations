# ==============================================
# The Writers Workbench — Environment Variables
# Copy this to .env and fill in the values
# ==============================================

# Supabase V2 (client-side — baked into React bundle)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# n8n Webhook (client-side)
VITE_N8N_WEBHOOK_URL=https://n8n.agileadautomation.com/webhook/author_request_v2

# ElevenLabs (client-side)
VITE_ELEVENLABS_AGENT_ID=agent_2801kks580vnf5q80j3bd0n0x45v

# Supabase (server-side only — never exposed to browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# n8n API (server-side only)
N8N_API_URL=https://n8n.agileadautomation.com
N8N_API_KEY=your-n8n-api-key

# Server
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173
