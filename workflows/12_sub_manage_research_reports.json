{
  "name": "Sub - Manage Research Reports",
  "nodes": [
    {
      "id": "rr-trigger",
      "name": "workflow_trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        0
      ],
      "parameters": {
        "workflowInputs": {
          "values": [
            {
              "name": "operation"
            },
            {
              "name": "report_id"
            },
            {
              "name": "topic"
            },
            {
