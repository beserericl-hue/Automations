      "parameters": {
        "url": "={{ $('settings').first().json.SUPABASE_URL }}/rest/v1/story_bible_v2?project_id=eq.{{ $('get_project').first().json.project?.id }}&order=entry_type,name{{ $('get_project').first().json.user_id ? '&user_id=eq.' + encodeURIComponent($('get_project').first().json.user_id) : '' }}",
        "sendHeaders": true,
