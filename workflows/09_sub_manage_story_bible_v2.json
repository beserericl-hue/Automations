      "id": "sb-get",
      "name": "get_story_bible",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        720,
        -96
      ]
    },
    {
      "parameters": {
        "jsCode": "const supabaseUrl = $('settings').first().json.SUPABASE_URL;\nconst apiKey = $('settings').first().json.SUPABASE_API_KEY;\nconst headers = { 'apikey': apiKey, 'Authorization': 'Bearer ' + apiKey, 'Content-Type': 'application/json' };\nconst projectId = $('get_project').first().json.project?.id;\nconst userId = $('get_project').first().json.user_id || '';\n\nif (!projectId) {\n  return [{ json: { result: 'Error: Project not found. Cannot update story bible.' } }];\n}\n\nconst entriesStr = $('workflow_trigger').first().json.entries || '[]';\nlet entries = [];\ntry {\n  entries = JSON.parse(entriesStr);\n} catch (e) {\n  // entries might already be an array/object\n  entries = Array.isArray(entriesStr) ? entriesStr : [entriesStr];\n}\n\nconst enriched = entries.map(e => ({ ...e, project_id: projectId, user_id: userId }));\n\ntry {\n  await this.helpers.httpRequest({\n    method: 'POST',\n    url: supabaseUrl + '/rest/v1/story_bible_v2',\n    headers: headers,\n    body: enriched\n  });\n} catch (e) {\n  return [{ json: { result: 'Error updating story bible: ' + e.message } }];\n}\n\nreturn [{ json: { result: 'Story bible updated with ' + entries.length + ' entries for project ' + $('workflow_trigger').first().json.project_title } }];"
      },
