    {
      "id": "ch-research-q",
      "name": "build_research_query",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        960,
        0
      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "crq1",
              "name": "research_query",
              "value": "=Research for chapter {{ $('workflow_trigger').item.json.chapter_number }} of a {{ $('get_genre_config').first().json[0]?.genre_name }} novel titled \"{{ $('workflow_trigger').item.json.project_title }}\". Chapter brief: {{ $('workflow_trigger').item.json.brief }}. Provide factual details about: {{ $('workflow_trigger').item.json.research_topics || $('workflow_trigger').item.json.brief }}.",
              "type": "string"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "ch-research",
      "name": "research_topic",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1200,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.perplexity.ai/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ model: 'sonar-reasoning', messages: [{ role: 'user', content: $json.research_query }] }) }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      }
    },
    {
      "id": "ch-prompt",
      "name": "build_chapter_prompt",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1440,
        0
      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "bcp1",
              "name": "prompt",
              "value": "=You are writing Chapter {{ $('workflow_trigger').item.json.chapter_number }} of \"{{ $('workflow_trigger').item.json.project_title }}\", a {{ $('get_genre_config').first().json[0]?.genre_name }} novel.\n\n## Genre Guidelines\n{{ $('get_genre_config').first().json[0]?.writing_guidelines }}\n\n## Research\n{{ $('research_topic').item.json.choices?.[0]?.message?.content || '' }}\n\n## Story Bible\n{{ JSON.stringify($('fetch_story_bible').first().json || []) }}\n\n## Outline\n{{ $('workflow_trigger').item.json.outline }}\n\n## This Chapter\n{{ $('workflow_trigger').item.json.brief }}\n\n## Requirements\n- Internal arc per chapter\n- End on a hook\n- Track character development\n- 3000-5000 words\n- Include scene breaks (---)\n\n## Output\nReturn JSON: { chapter_title, chapter_text, word_count, chapter_summary, next_chapter_notes, new_story_bible_entries }",
              "type": "string"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "ch-write",
      "name": "write_chapter",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.7,
      "position": [
        1680,
        0
      ],
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.prompt }}",
        "hasOutputParser": true,
        "batching": {}
      }
    },
    {
      "id": "ch-claude",
      "name": "claude-sonnet",
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1.3,
      "position": [
        1680,
        208
      ],
      "parameters": {
        "model": {
          "__rl": true,
          "value": "claude-sonnet-4-20250514",
          "mode": "list",
          "cachedResultName": "Claude Sonnet 4"
        },
        "options": {
          "maxTokensToSample": 16000
        }
      }
    },
    {
      "id": "ch-parser",
      "name": "chapter_parser",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        1872,
        208
      ],
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\"type\":\"object\",\"properties\":{\"chapter_title\":{\"type\":\"string\"},\"chapter_text\":{\"type\":\"string\"},\"word_count\":{\"type\":\"integer\"},\"chapter_summary\":{\"type\":\"string\"},\"next_chapter_notes\":{\"type\":\"string\"},\"new_story_bible_entries\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"entry_type\":{\"type\":\"string\"},\"name\":{\"type\":\"string\"},\"description\":{\"type\":\"string\"}}}}},\"required\":[\"chapter_title\",\"chapter_text\",\"word_count\",\"chapter_summary\",\"next_chapter_notes\"]}"
      }
    },
    {
      "id": "ch-update-bible",
      "name": "update_story_bible",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1920,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $('settings').item.json.SUPABASE_URL }}/rest/v1/story_bible",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify(($json.output?.new_story_bible_entries || []).map(e => ({ ...e, project_id: $('get_project').first().json[0]?.id, chapter_introduced: parseInt($('workflow_trigger').item.json.chapter_number), last_chapter_seen: parseInt($('workflow_trigger').item.json.chapter_number) }))) }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $('settings').item.json.SUPABASE_API_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $('settings').item.json.SUPABASE_API_KEY }}"
            }
          ]
        }
      }
    },
    {
      "id": "ch-update-proj",
