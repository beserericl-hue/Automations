      "parameters": {
        "method": "PATCH",
        "url": "={{ $('settings').item.json.SUPABASE_URL }}/rest/v1/writing_projects?id=eq.{{ $('get_project').first().json[0]?.id }}",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ chapter_count: parseInt($('workflow_trigger').item.json.chapter_number), status: 'in_progress', updated_at: $now.toISO() }) }}",
        "options": {},
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $('settings').item.json.SUPABASE_API_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $('settings').item.json.SUPABASE_API_KEY }}"
            }
          ]
        }
      }
    },
    {
      "id": "ch-save",
      "name": "save_draft",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2400,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $('settings').item.json.SUPABASE_URL }}/storage/v1/object/author-content/drafts/chapter_{{ $('workflow_trigger').item.json.project_title?.toLowerCase().replace(/[^a-z0-9]+/g, '-').substring(0, 30) || 'book' }}_ch{{ $('workflow_trigger').item.json.chapter_number }}_{{ $now.format('yyyy-MM-dd') }}.md",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "text/markdown",
        "body": "={{ $('write_chapter').item.json.output?.chapter_text || '' }}",
        "options": {},
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $('settings').item.json.SUPABASE_API_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $('settings').item.json.SUPABASE_API_KEY }}"
            }
          ]
        }
      }
    },
    {
      "id": "ch-email",
      "name": "send_email",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [
        2640,
        0
      ],
      "parameters": {
        "operation": "send",
        "sendTo": "eric@agileadtesting.com",
        "subject": "={{ $('workflow_trigger').item.json.project_title }} - Chapter {{ $('workflow_trigger').item.json.chapter_number }}: {{ $('write_chapter').item.json.output?.chapter_title || 'Draft' }}",
        "message": "={{ ($('write_chapter').item.json.output?.chapter_text || '').replace(/\\n/g, '<br>') }}",
        "options": {
          "appendAttribution": false
        }
      }
    },
    {
      "id": "ch-result",
      "name": "set_result",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        2880,
        0
      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "cr1",
              "name": "result",
              "value": "=Chapter {{ $('workflow_trigger').item.json.chapter_number }} written: {{ $('write_chapter').item.json.output?.chapter_title || 'Untitled' }} ({{ $('write_chapter').item.json.output?.word_count || 0 }} words)",
              "type": "string"
            }
          ]
        },
        "options": {}
      }
    }
