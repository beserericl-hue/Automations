    {
      "parameters": {
        "jsCode": "const supabaseUrl = $('settings').first().json.SUPABASE_URL;\nconst apiKey = $('settings').first().json.SUPABASE_API_KEY;\nconst headers = { 'apikey': apiKey, 'Authorization': 'Bearer ' + apiKey };\n\nlet files = [];\ntry {\n  const listResp = await this.helpers.httpRequest({\n    method: 'POST',\n    url: supabaseUrl + '/storage/v1/object/list/author-content',\n    headers: { ...headers, 'Content-Type': 'application/json' },\n    body: { prefix: 'writing-samples', limit: 20 },\n    returnFullResponse: false\n  });\n  files = (listResp || []).filter(f => f.name && f.name !== '.gitkeep' && f.metadata?.size > 0);\n} catch (e) {\n  return [{ json: { samples_text: 'No writing samples available.', sample_count: 0 } }];\n}\n\nif (files.length === 0) {\n  return [{ json: { samples_text: 'No writing samples available.', sample_count: 0 } }];\n}\n\nconst samples = [];\nfor (const file of files.slice(0, 5)) {\n  try {\n    const content = await this.helpers.httpRequest({\n      method: 'GET',\n      url: supabaseUrl + '/storage/v1/object/author-content/writing-samples/' + file.name,\n      headers: headers,\n      returnFullResponse: false,\n      encoding: 'utf-8',\n      json: false\n    });\n    samples.push('--- ' + file.name + ' ---\\n' + (typeof content === 'string' ? content : JSON.stringify(content)));\n  } catch (e) {}\n}\n\nconst samplesText = samples.length > 0 ? samples.join('\\n\\n') : 'No writing samples available.';\nreturn [{ json: { samples_text: samplesText, sample_count: samples.length } }];"
      },
      "id": "ss-samples",
      "name": "fetch_writing_samples",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        160
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze these writing samples and extract the author's distinctive style guidelines:\n\nSamples found: {{ $json.sample_count || 0 }}\n\n{{ $json.samples_text }}\n\nIf no samples are available, describe a general literary fiction style with vivid imagery and strong character voice.\n\nExtract and summarize: Voice, Pacing, Sentence structure, Dialogue style, Literary devices, Paragraph structure, Formatting rules.",
        "batching": {}
      },
