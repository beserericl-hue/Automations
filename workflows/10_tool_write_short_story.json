    {
      "parameters": {
        "jsCode": "const storyText = $input.first().json.output || $input.first().json.text || '';\nconst title = $('build_story_prompt').first().json.title || 'Untitled';\nconst trigger = $('workflow_trigger').first().json;\nconst genre = $('get_genre_config').first().json;\nconst genreData = Array.isArray(genre) ? genre[0] : genre;\nconst genreName = genreData?.genre_name || 'Science Fiction';\n\n// Extract the opening scene (first ~300 words) for visual reference\nconst openingScene = storyText.split(/\\n---\\n|\\n\\n/)[0]?.substring(0, 1200) || storyText.substring(0, 1200);\n\n// Build a rich visual image description from the story content\nconst imagePrompt = `A cinematic, atmospheric cover image for a ${genreName} short story titled \"${title}\".\n\nStory premise: ${trigger.premise}\nTone: ${trigger.tone || 'literary'}\n\nKey scene from the opening:\n${openingScene}\n\nCreate a single powerful visual scene that captures the mood, setting, and central tension of this story. Focus on the most visually striking moment \u2014 the environment, lighting, character silhouettes, and atmospheric details. Do NOT include any text, titles, or words in the image.`;\n\nreturn [{ json: { story_text: storyText, title: title, image_prompt: imagePrompt } }];"
      },
